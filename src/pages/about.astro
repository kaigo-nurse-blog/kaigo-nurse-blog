---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title="プロフィール | 介護ナースのリアル" description="介護士から看護師になった精神科ナースのプロフィールページです。" />
		<style>
			main {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em;
			}

			/* ページタイトル */
			.page-title {
				text-align: center;
				margin-bottom: 2.5em;
			}
			.page-title h1 {
				font-size: 1.8em;
				color: #7A4A2A;
				margin-bottom: 0.3em;
			}
			.page-title .subtitle {
				font-size: 0.85em;
				color: #A06040;
				letter-spacing: 0.05em;
			}
			.title-divider {
				width: 50px;
				height: 3px;
				background: linear-gradient(to right, #E8925A, #FFD8A8);
				margin: 0.8em auto 0;
				border-radius: 2px;
			}

			/* プロフィールカード */
			.profile-card {
				background: linear-gradient(135deg, #FFF9F2, #FFF0E0);
				border-radius: 16px;
				padding: 2em;
				margin-bottom: 1.8em;
				border: 1px solid #F5D9B8;
				box-shadow: 0 2px 12px rgba(200, 120, 60, 0.08);
			}

			/* アイコン＋名前エリア */
			.profile-header {
				display: flex;
				align-items: center;
				gap: 1.2em;
				margin-bottom: 1.5em;
			}
			.profile-avatar {
				width: 72px;
				height: 72px;
				border-radius: 50%;
				background: linear-gradient(135deg, #E8925A, #FFD8A8);
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 2em;
				flex-shrink: 0;
				box-shadow: 0 2px 8px rgba(200, 120, 60, 0.2);
			}
			.profile-name h2 {
				font-size: 1.3em;
				color: #5A3010;
				margin: 0 0 0.2em;
			}
			.profile-name .job-title {
				font-size: 0.8em;
				color: #A06040;
				background: #FFE5C8;
				padding: 0.2em 0.8em;
				border-radius: 20px;
				display: inline-block;
			}

			/* 各セクション */
			.section {
				background: #fff;
				border-radius: 12px;
				padding: 1.4em 1.6em;
				margin-bottom: 1.2em;
				border-left: 4px solid #E8925A;
				box-shadow: 0 1px 6px rgba(200, 120, 60, 0.06);
			}
			.section-label {
				font-size: 0.72em;
				font-weight: bold;
				color: #E8925A;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				margin-bottom: 0.6em;
			}
			.section-content {
				color: #4A3020;
				font-size: 0.9em;
				line-height: 1.8;
			}

			/* 経歴タイムライン */
			.timeline {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.timeline li {
				display: flex;
				align-items: flex-start;
				gap: 0.8em;
				padding: 0.4em 0;
				font-size: 0.88em;
				color: #4A3020;
				line-height: 1.6;
			}
			.timeline li::before {
				content: '';
				width: 8px;
				height: 8px;
				border-radius: 50%;
				background: #E8925A;
				flex-shrink: 0;
				margin-top: 0.55em;
			}
			.timeline li:not(:last-child) {
				border-bottom: 1px dashed #F5D9B8;
			}
			.timeline .current {
				font-weight: bold;
				color: #C05010;
			}

			/* 資格バッジ */
			.badge-list {
				display: flex;
				gap: 0.6em;
				flex-wrap: wrap;
			}
			.badge {
				background: linear-gradient(135deg, #E8925A, #D07040);
				color: #fff;
				padding: 0.3em 1em;
				border-radius: 20px;
				font-size: 0.8em;
				font-weight: bold;
				letter-spacing: 0.03em;
			}

			/* 一言カード */
			.catchphrase-card {
				background: linear-gradient(135deg, #E8925A, #C06030);
				border-radius: 16px;
				padding: 1.8em 2em;
				text-align: center;
				color: #fff;
				margin-top: 2em;
				box-shadow: 0 4px 16px rgba(200, 100, 40, 0.25);
			}
			.catchphrase-card .quote-mark {
				font-size: 2em;
				opacity: 0.5;
				line-height: 1;
				margin-bottom: 0.2em;
			}
			.catchphrase-card .quote-text {
				font-size: 1.1em;
				font-weight: bold;
				letter-spacing: 0.05em;
				line-height: 1.7;
			}
			.catchphrase-card .quote-note {
				font-size: 0.75em;
				opacity: 0.8;
				margin-top: 0.8em;
			}

			/* レスポンシブ */
			@media (max-width: 520px) {
				.profile-header {
					flex-direction: column;
					text-align: center;
				}
				.badge-list {
					justify-content: center;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<!-- ページタイトル -->
			<div class="page-title">
				<h1>プロフィール</h1>
				<p class="subtitle">このブログを書いている人</p>
				<div class="title-divider"></div>
			</div>

			<!-- プロフィールカード -->
			<div class="profile-card">
				<div class="profile-header">
					<div class="profile-avatar">🏥</div>
					<div class="profile-name">
						<h2>介護ナース</h2>
						<span class="job-title">精神科看護師</span>
					</div>
				</div>

				<!-- 経歴 -->
				<div class="section">
					<div class="section-label">📋 経歴</div>
					<ul class="timeline">
						<li>介護福祉士養成校 卒業</li>
						<li>老健（介護老人保健施設）勤務</li>
						<li>准看護師学校 修了</li>
						<li>正看護師学校 修了</li>
						<li>急性期病院 勤務</li>
						<li class="current">精神科病院 勤務（現在）</li>
					</ul>
				</div>

				<!-- 資格 -->
				<div class="section">
					<div class="section-label">🎓 資格</div>
					<div class="badge-list">
						<span class="badge">介護福祉士</span>
						<span class="badge">看護師</span>
						<span class="badge">FP3級</span>
					</div>
				</div>

				<!-- ブログテーマ -->
				<div class="section">
					<div class="section-label">✍️ このブログについて</div>
					<div class="section-content">
						介護士から看護師を目指す人、准看から正看を目指す人、精神科に興味がある人に向けて、現場の本音をお届けします。2026年にFP3級を取得し、お金の面からも医療・介護の現場をサポートしたいと考えています。
					</div>
				</div>
			</div>

			<!-- 一言 -->
			<div class="catchphrase-card">
				<div class="quote-mark">❝</div>
				<div class="quote-text">知らなかっただけで、諦めなくていい</div>
				<div class="quote-note">— 介護ナース</div>
			</div>
		</main>
		<Footer />
	</body>
</html>
